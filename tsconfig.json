{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".vercel/output",
    "rootDir": ".",
    "noEmit": true
  },
  "include": ["api/**/*", "lib/**/*"],
  "exclude": ["node_modules", "web"]
}
